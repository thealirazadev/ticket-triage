# API key for the LLM provider API. Required. Dummy value shown.
LLM_API_KEY=llm-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL of the LLM provider API (chat-completions-style endpoint). Required.
LLM_BASE_URL=https://api.example-provider.com/v1

# Model id passed to the provider. Required.
LLM_MODEL=example-model-id

# Per-request read timeout for provider calls, in seconds. Optional; default shown.
LLM_TIMEOUT_SECONDS=30

# Extra attempts after the first failed provider call (timeout, 429, 5xx). Optional.
LLM_MAX_RETRIES=2

# Provider prices in USD per million tokens, used for per-ticket cost tracking.
# Optional; when 0, cost is recorded as 0 and only tokens/latency are meaningful.
LLM_PRICE_INPUT_PER_MTOK=0
LLM_PRICE_OUTPUT_PER_MTOK=0

# SQLAlchemy database URL. SQLite in dev; a postgresql+psycopg URL in prod.
DATABASE_URL=sqlite:///./data/tickets.db

# Optional API key. If set, all routes except GET /health require a matching
# X-API-Key header. Leave empty to run open (local use).
API_KEY=

# Queue used when no routing rule matches or triage falls back to needs_human.
DEFAULT_QUEUE=general

# Background worker: enabled flag and poll interval in seconds.
WORKER_ENABLED=true
WORKER_POLL_SECONDS=2

# Circuit breaker: consecutive provider failures before opening, and how long
# the circuit stays open, in seconds.
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_COOLDOWN_SECONDS=60

# Eval gate: maximum allowed drop vs the stored baseline (absolute, e.g. 0.02
# means two percentage points of accuracy or macro-F1).
EVAL_REGRESSION_THRESHOLD=0.02

# Logging level (DEBUG, INFO, WARNING, ERROR). Optional; default shown.
LOG_LEVEL=INFO
